{
  "name": "facet-clock",
  "version": "1.0.0",
  "description": "Facet — Minimal Clock Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:exe": "npx -y @electron/packager . FacetClock --platform=win32 --arch=x64 --icon=logo.ico --out=pc_app_final --overwrite --prune=true --ignore=\"pc_app\" --ignore=\"installer\" --ignore=\"dist\" --electron-version=28.2.0",
    "build:installer": "npx -y electron-builder --win nsis"
  },
  "build": {
    "appId": "com.facet.clock",
    "productName": "Facet Clock",
    "electronVersion": "28.2.0",
    "asar": true,
    "compression": "normal",
    "publish": null,
    "directories": {
      "output": "installer_dist_final"
    },
    "win": {
      "target": "nsis",
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": false,
      "shortcutName": "Facet Clock",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "files": [
      "index.html",
      "styles.css",
      "main.js",
      "preload.js",
      "sw.js",
      "manifest.json",
      "logo.png",
      "logo.ico",
      "palettes.facet",
      "color-themes.facet",
      "js/**/*",
      "public/**/*",
      "!node_modules/**",
      "!pc_app*/**",
      "!installer_build*/**",
      "!installer_dist*/**",
      "!build*/**",
      "!dist*/**",
      "!context*/**"
    ]
  },
  "devDependencies": {
    "electron": "28.2.0",
    "electron-builder": "^24.9.0"
  },
  "keywords": [
    "clock",
    "minimal",
    "electron",
    "desktop-app",
    "installer"
  ],
  "author": "Antigravity Agent",
  "license": "MIT"
}
